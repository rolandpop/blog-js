---
layout: layouts/base.njk
permalink: /blog/index.html
title: Blog
description: Articles on software architecture, SOLID principles, and .NET development.
pagination:
  data: collections.posts
  size: 10
  alias: posts
---
<section class="page-header-block">
  <h1>Blog</h1>
  <p>Thoughts on software architecture, design principles, and building maintainable systems.</p>
</section>

<ul class="post-list">
  {% for post in posts %}
    <li class="post-card">
      <a href="{{ post.url }}">
        <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        <h2>{{ post.data.title }}</h2>
        {% if post.data.description %}
          <p>{{ post.data.description }}</p>
        {% endif %}
        {% if post.data.tags and post.data.tags.length %}
          <div class="post-tags">
            {% for tag in post.data.tags %}
              <span class="tag">{{ tag }}</span>
            {% endfor %}
          </div>
        {% endif %}
      </a>
    </li>
  {% endfor %}
</ul>

{% if pagination.pages.length > 1 %}
  <nav class="pagination" aria-label="Blog pagination">
    {% if pagination.href.previous %}
      <a href="{{ pagination.href.previous }}">← Newer</a>
    {% endif %}
    <span>Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>
    {% if pagination.href.next %}
      <a href="{{ pagination.href.next }}">Older →</a>
    {% endif %}
  </nav>
{% endif %}
